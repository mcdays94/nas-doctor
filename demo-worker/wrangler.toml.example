name = "nas-doctor-demo"
main = "src/index.ts"
compatibility_date = "2024-12-30"
account_id = ""  # Your Cloudflare account ID
workers_dev = false

[vars]
DEMO_MODE = "true"

[assets]
directory = "./captured"
binding = "ASSETS"

# Custom domain
[[routes]]
pattern = "your-demo-domain.example.com"
custom_domain = true

# KV namespace for demo API data
[[kv_namespaces]]
binding = "DEMO_DATA"
id = ""  # Your KV namespace ID
