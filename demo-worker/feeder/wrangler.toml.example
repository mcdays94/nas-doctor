name = "nas-doctor-demo-feeder"
main = "src/index.ts"
compatibility_date = "2024-12-30"
account_id = ""  # Your Cloudflare account ID
workers_dev = true

[triggers]
crons = ["*/5 * * * *"]

# Same KV namespace as the demo worker
[[kv_namespaces]]
binding = "DEMO_DATA"
id = ""  # Your KV namespace ID
